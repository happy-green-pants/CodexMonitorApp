# Codex Monitor Daemon Configuration Example
# Copy this file to .env and update the values as needed

# Required: Authentication token for TCP clients
# Generate a secure random token: openssl rand -hex 32
CODEX_MONITOR_DAEMON_TOKEN=your-secret-token-here

# Optional: TCP listen address (default: 127.0.0.1:4732)
# Set to 0.0.0.0:4732 to accept connections from any IP address
LISTEN_ADDR=127.0.0.1:4732

# Optional: HTTP listen address for browser access (default: disabled)
# Uncomment to enable HTTP/WS access
# HTTP_LISTEN_ADDR=0.0.0.0:9010

# Optional: Data directory path (default: ./data)
# This directory will contain workspaces.json and settings.json
DATA_DIR=./data
